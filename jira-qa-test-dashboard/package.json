{
  "name": "jira-qa-test-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Dashboard: Jira ticket → test cases → Playwright execution on a target URL",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  }
}
