# Jira Cloud (create API token: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_token

# Optional: smarter test-case + step generation (JSON with runnable Playwright steps)
OPENAI_API_KEY=

# Dashboard API port
PORT=3847

# Production: set NODE_ENV=production on your host
# NODE_ENV=production

# Optional: shared secret so only your team can call POST /api/* (health stays public).
# Users paste the same value once in the UI ("Team access token").
# DASHBOARD_TOKEN=

# Optional: full public URL (shown in server logs only)
# PUBLIC_BASE_URL=https://qa-dashboard.yourcompany.com

# Optional: behind Render / Fly / nginx TLS termination
# TRUST_PROXY=1
